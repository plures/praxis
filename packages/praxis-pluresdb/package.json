{
  "name": "@plures/praxis-pluresdb",
  "version": "0.1.0",
  "description": "PluresDB native backend for the Praxis logic engine — constraint execution via NAPI procedure engine",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@plures/pluresdb": ">=2.9.0",
    "@plures/praxis-core": ">=0.1.0"
  },
  "devDependencies": {
    "@plures/praxis-core": "workspace:*",
    "@types/node": "^25.0.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  },
  "keywords": ["praxis", "pluresdb", "napi", "constraint-engine", "logic-engine"],
  "author": "Plures",
  "license": "MIT",
  "publishConfig": { "access": "public" }
}
